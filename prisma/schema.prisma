// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessagePrivacy {
  EVERYONE
  FOLLOWERS
}

model User {
  id             String    @id @default(uuid())
  username       String    @unique
  email          String    @unique
  passwordHash   String
  displayName    String?
  profilePicture String?   @default("https://via.placeholder.com/150")
  bio            String?
  gender         String?
  showGender     Boolean   @default(false)
  isPrivate      Boolean   @default(false)
  isVerified     Boolean   @default(false)
  pushToken      String?
  messagePrivacy          MessagePrivacy @default(EVERYONE)
  hideOnlineStatus        Boolean        @default(false)
  lastSeen                DateTime?
  closeFriends            String[]       @default([])
  hiddenStoryFrom         String[]       @default([]) // user IDs hidden from seeing my stories
  disappearingMsgTimer    String?        // null | "24h" | "7d"
  createdAt               DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  resetCode        String?
  resetCodeExpires DateTime?
  deletionCode     String?
  deletionCodeExpiry DateTime?
  publicKey        String?   // E2EE public key for end-to-end encryption

  posts          Post[]    @relation("PostOwner")
  collabPosts    Post[]    @relation("PostCollab")
  likes          Like[]
  saves          Save[]
  comments       Comment[]
  stories        Story[]
  storyViews     StoryView[]
  storyReactions StoryReaction[]
  storyComments  StoryComment[]
  storyPollVotes StoryPollVote[]
  groupMembers   GroupMember[]
  groupMessages  GroupMessage[] @relation("GroupMessageSender")
  groupMessageReactions GroupMessageReaction[]
  
  // Follow System
  followers      Follow[]  @relation("FollowedUser")
  following      Follow[]  @relation("FollowingUser")
  
  // Direct Messages
  sentMessages     Message[] @relation("SentMessages")
  messageReactions MessageReaction[]
  notes            Note[]
  chatRoomsAs1     ChatRoom[] @relation("ChatRoomUser1")
  chatRoomsAs2     ChatRoom[] @relation("ChatRoomUser2")
  blocksInitiated  Block[]   @relation("Blocker")
  blocksReceived   Block[]   @relation("Blocked")
  
  notifications    Notification[]
}

model Post {
  id             String    @id @default(uuid())
  userId         String
  type           String    // "image" or "reel"
  mediaUrl       String    // Cloudflare R2 URL
  thumbnailUrl   String?   // Picsum or Cloudflare R2 URL
  caption        String?
  category       String?   // "cricket", "tech", "gaming", "music"
  aspectRatio    Float?
  hideLikes      Boolean   @default(false)
  hideShares     Boolean   @default(false)
  collabUserId   String?   // the invited collab partner
  collabStatus   String?   // "pending" | "accepted" | "declined"
  scheduledAt    DateTime?
  isScheduled    Boolean   @default(false)
   visibility     String    @default("public") // "public" | "private" | "unlisted" | "close_friends"
  viewCount      Int       @default(0)
  shareCount     Int       @default(0)
  createdAt      DateTime  @default(now())

  user           User      @relation("PostOwner", fields: [userId], references: [id], onDelete: Cascade)
  collabUser     User?     @relation("PostCollab", fields: [collabUserId], references: [id], onDelete: SetNull)
  likes          Like[]
  saves          Save[]
  comments       Comment[]
  postViews      PostView[]
}

model PostView {
  id        String   @id @default(uuid())
  postId    String
  userId    String?  // null for anonymous/non-logged views
  gender    String?  // viewer's gender from their profile
  country   String?  // viewer's country
  device    String?  // "iPhone" | "Android" | "Web"
  source    String?  // "home" | "explore" | "search" | "direct" | "profile"
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Follow {
  id             String    @id @default(uuid())
  followerId     String
  followingId    String
  status         String    @default("accepted") // "pending" or "accepted"
  createdAt      DateTime  @default(now())

  follower       User      @relation("FollowingUser", fields: [followerId], references: [id], onDelete: Cascade)
  following       User      @relation("FollowedUser", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Like {
  id             String    @id @default(uuid())
  userId         String
  postId         String
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Save {
  id             String    @id @default(uuid())
  userId         String
  postId         String
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id             String    @id @default(uuid())
  userId         String
  postId         String
  text           String
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Story {
  id             String    @id @default(uuid())
  userId         String
  mediaUrl       String
  audience       String    @default("everyone") // "everyone" | "close_friends"
  stickerData    Json?     // Stores stickers (poll, mention, location, hashtag, etc.)
  frameData      Json?     // Stores { scale, x, y } for pinch-zoom & drag positioning
  createdAt      DateTime  @default(now())
  expiresAt      DateTime  // 24 hours after creation

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  views          StoryView[]
  reactions      StoryReaction[]
  comments       StoryComment[]
  pollVotes      StoryPollVote[]
}

model StoryPollVote {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  option    Int      // 0 or 1 (which poll option)
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
}

model StoryView {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
}

model StoryReaction {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  emoji     String   // e.g., "❤️", "😂", "😮", "😢", "😡"
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
}

model StoryComment {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  text      String
  createdAt DateTime  @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// —————————————————————————————
// CHAT SYSTEM (Messages + Rooms)
// —————————————————————————————

// 1-on-1 conversation thread
model ChatRoom {
  id              String    @id @default(uuid())
  user1Id         String
  user2Id         String
  isAccepted      Boolean   @default(false)
  // Mute: stored as comma-separated userIds who muted messages/calls
  mutedMessages   String[]  @default([])
  mutedCalls      String[]  @default([])
  // Soft-delete per user: stores userId of whoever deleted their copy
  deletedFor      String[]  @default([])
  deletedForAt    DateTime?
  // Vanish mode (per-user — userIds who have it enabled)
  vanishMode      String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user1      User      @relation("ChatRoomUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2      User      @relation("ChatRoomUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

// Each message belongs to a ChatRoom
model Message {
  id        String   @id @default(uuid())
  roomId    String
  senderId  String
  text      String?
  type      String   @default("text") // text | image | gif | audio | reel_share | post_share | story_reply
  mediaUrl  String?
  postId    String?
  storyId   String?
  replyToId String?  // For reply-to-message
  status    String   @default("SENT") // SENT | DELIVERED | SEEN

  // For audio messages
  audioDuration Int?    // seconds

  // Vanish mode
  isVanish  Boolean  @default(false)
  seenAt    DateTime?

  // Edit within 15 min
  edited    Boolean  @default(false)
  editedAt  DateTime?

  // Pin / Unpin
  isPinned  Boolean  @default(false)
  pinnedAt  DateTime?

  // Soft delete per-user
  deletedFor String[] @default([])

  // E2EE: encrypted message data (format: iv:ciphertext:tag)
  isEncrypted    Boolean  @default(false)
  encryptedData  String?  // stored if text is encrypted

  // Scheduled send
  scheduledAt DateTime?

  createdAt DateTime @default(now())

  room      ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  reactions MessageReaction[]
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")

  @@index([roomId, createdAt])
  @@index([senderId])
}

// Reactions on messages (one reaction per user per message)
model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
}

// Block relationship
model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  senderId    String
  type        String   // "follow_accepted", "like", "comment", "story_reaction", "story_comment", "message"
  text        String?
  postId      String?
  storyId     String?  // For story-related notifications
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Notes (24h disappearing text status, visible to followers) ──
model Note {
  id        String   @id @default(uuid())
  userId    String   @unique  // one active note per user
  text      String
  emoji     String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ── Group Chats ──
model Group {
  id                     String        @id @default(uuid())
  name                   String
  avatar                 String?
  description            String?
  allowMembersToInvite   Boolean       @default(false)
  onlyAdminsCanSend      Boolean       @default(false)
  membersCanEditProfile  Boolean       @default(false)
  createdById            String
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  members     GroupMember[]
  messages    GroupMessage[]
  polls       GroupPoll[]

  @@index([createdById])
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  role      String   @default("member")  // owner | admin | member
  joinedAt  DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupMessage {
  id        String   @id @default(uuid())
  groupId   String
  senderId  String
  text      String?
  type      String   @default("text") // text | image | gif | audio | system
  mediaUrl  String?
  audioDuration Int?
  replyToId String?
  edited    Boolean  @default(false)
  editedAt  DateTime?
  isPinned  Boolean  @default(false)
  deletedFor String[] @default([])
  createdAt DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User     @relation("GroupMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  reactions GroupMessageReaction[]

  @@index([groupId, createdAt])
  @@index([senderId])
}

model GroupMessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message   GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model GroupPoll {
  id        String   @id @default(uuid())
  groupId   String
  creatorId String
  question  String
  options   String[]
  createdAt DateTime @default(now())
  expiresAt DateTime?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  votes GroupPollVote[]

  @@index([groupId])
}

model GroupPollVote {
  id       String @id @default(uuid())
  pollId   String
  userId   String
  optionIdx Int

  poll GroupPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String
  category    String
  description String
  images      String[]
  createdAt   DateTime @default(now())
}


// ── Creator Monetization Applications ──
model MonetizationApplication {
  id             String   @id @default(uuid())
  userId         String
  fullName       String
  email          String
  phone          String?
  contentType    String   // "reels" | "posts" | "both"
  niche          String?  // "gaming" | "tech" | "music" | "lifestyle" etc.
  followers      Int
  views30d       Int
  paymentMethod  String?  // "upi" | "bank" | "paypal"
  paymentDetails String?  // UPI ID or bank details
  status         String   @default("pending") // "pending" | "approved" | "rejected"
  adminNotes     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
